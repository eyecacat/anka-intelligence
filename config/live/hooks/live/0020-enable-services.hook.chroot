#!/bin/sh

# 1. Kullanıcıyı oluştur (Eğer yoksa)
if ! id "anka" &>/dev/null; then
    useradd -m -s /bin/bash anka
    echo "[HOOK] 'anka' kullanıcısı oluşturuldu."
fi

# 2. Şimdi yetkileri ver
chown -R anka:anka /opt/anka

# 3. Servisleri enable et
systemctl enable yon-core.service
systemctl enable anka-kiosk.service
systemctl enable anka-watchdog.service
